<?xml version="1.0" encoding="UTF-8"?>
<project default="generate" name="EcoRoute.generator.sql">
    <property name="ECLIPSE_HOME" value="../../../eclipse/java-2025-06/eclipse"/>
    <property name="ECLIPSE_WORKSPACE" value="../.."/>

    <!-- The classpath with only the dependencies used by the project -->
    <path id="EcoRoute.generator.sql.libraryclasspath">
        <pathelement location="${ECLIPSE_WORKSPACE}/EcoRoute.generator.sql/bin"/>
    </path>

    <path id="EcoRoute.generator.sql.classpath">
        <path refid="EcoRoute.generator.sql.libraryclasspath"/>
    </path>

    <!-- The classpath with only the jars available in the plugin folder of Eclipse -->
    <path id="EcoRoute.generator.sql.libraryclasspath.alljars">
        <pathelement location="../EcoRoute.generator.sql/bin"/>
        <fileset dir="${ECLIPSE_HOME}/plugins/" includes="*.jar"/>
    </path>

    <path id="EcoRoute.generator.sql.classpath.alljars">
        <path refid="EcoRoute.generator.sql.libraryclasspath.alljars"/>
    </path>

    <!-- The default task with the jars used by this project -->
    <target name="generate">
        <java classname="EcoRoute.generator.sql.common.Generate" classpathref="EcoRoute.generator.sql.classpath">
            <arg value="${model}"/>
            <arg value="${target}"/>
        </java>
    </target>

    <!--
        In case of problem you can also try with all the jar available in your Eclipse
        Keep in mind that having two versions of the same jar can create problems
    -->
    <target name="generate.alljars">
        <java classname="EcoRoute.generator.sql.common.Generate" classpathref="EcoRoute.generator.sql.classpath">
            <arg value="${model}"/>
            <arg value="${target}"/>
        </java>
    </target>
</project>
